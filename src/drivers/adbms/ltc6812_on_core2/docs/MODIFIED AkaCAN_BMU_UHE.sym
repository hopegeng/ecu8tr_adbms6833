[M001_BMSInfo]
ID=10005801h // module version and Error information (module version and Error information)
Type=Extended
DLC=8
CycleTime=1000
Var=M001_flag_CalibrationDone bit 0,1 /e:VtSig_M001_flag_CalibrationDone // shows if module is calibrated
Var=M001_flag_CalibrationIncomp bit 1,1 /e:VtSig_M001_flag_CalibrationDone // shows if calibration data is missing
Var=M001_flag_CalibrationError bit 2,1 /e:VtSig_M001_flag_CalibrationDone // shows if there was an error while calibrating or calibration data is out of limits
Var=M001_flag_EEPROMError bit 4,1 /e:VtSig_M001_flag_CalibrationDone // shows if there was an error while reading/writig to EEPROM
Var=M001_flag_WDGError bit 5,1 /e:VtSig_M001_flag_CalibrationDone // shows if Watchdog has been triggered
Var=M001_flag_ConfigDone bit 6,1 /e:VtSig_M001_flag_CalibrationDone // shows if serial number has been set and topology has been set and locked
Var=M001_flag_TempCalErr bit 7,1 /e:VtSig_M001_flag_CalibrationDone // shows if there has been an error with the temperature calibration
Var=M001_flag_SerialMiss bit 10,1 /e:VtSig_M001_flag_CalibrationDone // shows if module serial number has not been set
Var=M001_flag_ThermalShtDwn_IC1 bit 11,1 /e:VtSig_M001_flag_CalibrationDone // shows if IC 1 has a temperature over 125 °C
Var=M001_flag_ThermalShtDwn_IC2 bit 12,1 /e:VtSig_M001_flag_CalibrationDone // shows if IC 2 has a temperature over 125 °C
Var=M001_flag_ThermalShtDwn_IC3 bit 13,1 /e:VtSig_M001_flag_CalibrationDone // shows if IC 3 has a temperature over 125 °C
Var=M001_flag_ThermalShtDwn_IC4 bit 14,1 /e:VtSig_M001_flag_CalibrationDone // shows if IC 4 has a temperature over 125 °C
Var=M001_flag_SelfTestPassed bit 16,1 /e:VtSig_M001_flag_CalibrationDone // shows if all self-tests have been passed
Var=M001_flag_SM_PollTimeout bit 22,1 /e:VtSig_M001_flag_CalibrationDone // isoSPI ADC polling timeout or too many ICs connected during execution of any safety mechanism
Var=M001_flag_NoSafRel_PollTimeout bit 23,1 /e:VtSig_M001_flag_CalibrationDone // isoSPI ADC polling timeout or too many ICs connected during execution of any not safety relevant command
Var=M001_flag_SM_BadCRC_IC1 bit 24,1 /e:VtSig_M001_flag_CalibrationDone // isoSPI communication error during execution of any safety mechanism
Var=M001_flag_SM_BadCRC_IC2 bit 25,1 /e:VtSig_M001_flag_CalibrationDone // isoSPI communication error during execution of any safety mechanism
Var=M001_flag_SM_BadCRC_IC3 bit 26,1 /e:VtSig_M001_flag_CalibrationDone // isoSPI communication error during execution of any safety mechanism
Var=M001_flag_SM_BadCRC_IC4 bit 27,1 /e:VtSig_M001_flag_CalibrationDone // isoSPI communication error during execution of any safety mechanism
Var=M001_flag_NoSafRel_BadCRC_IC1 bit 28,1 /e:VtSig_M001_flag_CalibrationDone // isoSPI communication error during execution any not safety relevant command
Var=M001_flag_NoSafRel_BadCRC_IC2 bit 29,1 /e:VtSig_M001_flag_CalibrationDone // isoSPI communication error during execution any not safety relevant command
Var=M001_flag_NoSafRel_BadCRC_IC3 bit 30,1 /e:VtSig_M001_flag_CalibrationDone // isoSPI communication error during execution any not safety relevant command
Var=M001_flag_NoSafRel_BadCRC_IC4 bit 31,1 /e:VtSig_M001_flag_CalibrationDone // isoSPI communication error during execution any not safety relevant command
Var=M001_flag_BadCRC_IC1 bit 32,1 /e:VtSig_M001_flag_CalibrationDone // isoSPI communication error
Var=M001_flag_BadCRC_IC2 bit 33,1 /e:VtSig_M001_flag_CalibrationDone // isoSPI communication error
Var=M001_flag_BadCRC_IC3 bit 34,1 /e:VtSig_M001_flag_CalibrationDone // isoSPI communication error
Var=M001_flag_BadCRC_IC4 bit 35,1 /e:VtSig_M001_flag_CalibrationDone // isoSPI communication error
Var=M001_flag_PollTimeout bit 36,1 /e:VtSig_M001_flag_CalibrationDone // isoSPI ADC polling timeout or too many ICs connected
Var=M001_flag_ComplSafAreaCRCErr bit 37,1 /e:VtSig_M001_flag_CalibrationDone // both EEPROM safety areas contain a bad CRC
Var=M001_flag_ComplStatAreaCRCErr bit 38,1 /e:VtSig_M001_flag_CalibrationDone // both EEPROM static areas contain a bad CRC
Var=M001_flag_ComplDynAreaCRCErr bit 39,1 /e:VtSig_M001_flag_CalibrationDone // both EEPROM dynamic areas contain a bad CRC
Var=M001_flag_InitialisationFail bit 40,1 /e:VtSig_M001_flag_CalibrationDone // isoSPI module in BMU was not initalised successfully
Var=M001_flag_SingleSafAreaCRCErr bit 41,1 /e:VtSig_M001_flag_CalibrationDone // one of EEPROM safety areas is corrupted
Var=M001_flag_SingleStatAreaCRCErr bit 42,1 /e:VtSig_M001_flag_CalibrationDone // one of EEPROM static areas is corrupted
Var=M001_flag_SingleDynAreaCRCErr bit 43,1 /e:VtSig_M001_flag_CalibrationDone // one of EEPROM dynamic areas is corrupted
Var=M001_flag_SafAreaMismatch bit 44,1 /e:VtSig_M001_flag_CalibrationDone // CRC of both EEPROM safety areas is correct, but content doesn't match
Var=M001_flag_StatAreaMismatch bit 45,1 /e:VtSig_M001_flag_CalibrationDone // CRC of both EEPROM static areas is correct, but content doesn't match
Var=M001_flag_IDPageNotLocked bit 46,1 /e:VtSig_M001_flag_CalibrationDone // EEPROM ID page is not locked
Var=M001_flag_I2CCommunicationFail bit 47,1 /e:VtSig_M001_flag_CalibrationDone // I2C communication error
