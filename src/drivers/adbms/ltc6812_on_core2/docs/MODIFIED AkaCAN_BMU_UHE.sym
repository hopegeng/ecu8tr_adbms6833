[SCU1_Status]
ID=08001401h // SCU status message (SCU status message)
Type=Extended
DLC=8
CycleTime=40
Var=SCU1_stat_Init bit 0,1 /e:VtSig_SCU1_stat_Init // initialisation of SCU components
Var=SCU1_stat_Run bit 1,1 /e:VtSig_SCU1_stat_Init // selftests are finished
Var=SCU1_stat_Error bit 2,1 /e:VtSig_SCU1_stat_Init // SCU has encountered an error
Var=SCU1_stat_Config bit 3,1 /e:VtSig_SCU1_stat_Init // SCU is beeing configured
Var=SCU1_stat_LimpHome bit 4,1 /e:VtSig_SCU1_stat_Init // limp home modus with limited functionallity
Var=SCU1_stat_Diag bit 5,1 /e:VtSig_SCU1_stat_Init // SCU is in diagnostic mode
Var=SCU1_stat_Shutdown bit 8,1 /e:VtSig_SCU1_stat_Init // KL15 is off, SCU shutdown started
Var=SCU1_stat_ART_Started bit 9,1 /e:VtSig_SCU1_stat_Init // Afterrun test started
Var=SCU1_stat_ART_IsActive bit 10,1 /e:VtSig_SCU1_stat_Init // Afterrun test is running
Var=SCU1_stat_ART_NoError bit 11,1 /e:VtSig_SCU1_stat_Init // No Error While After Run Test
Var=SCU1_stat_ART_BMSS_Restart bit 12,1 /e:VtSig_SCU1_stat_Init // Restart of BMS-Slaves is performed
Var=SCU1_flag_PowerContPos bit 16,1 /e:VtSig_SCU1_flag_PowerContPos // state of power contactor +
Var=SCU1_flag_PowerContNeg bit 17,1 /e:VtSig_SCU1_flag_PowerContPos // state of power contactor -
Var=SCU1_flag_PowerContPre bit 18,1 /e:VtSig_SCU1_flag_PowerContPos // state of power contactor precharge
Var=SCU1_flag_PowerContExtAux bit 19,1 /e:VtSig_SCU1_flag_PowerContPos // state of extended aux power contactor
Var=SCU1_stat_ConOnProtect bit 20,1 /e:VtSig_SCU1_stat_Init // contactor protection flag after contactor drop-out
Var=SCU1_flag_ShuntResCalibration bit 22,1 /e:VtSig_SCU1_stat_Init // state of the shunt resistance calibration
Var=SCU1_flag_EoL_Mode bit 23,1 /e:VtSig_SCU1_stat_Init // state of the EoL mode
Var=SCU1_flag_VSenserelayPosInt bit 24,1 /e:VtSig_SCU1_flag_PowerContPos // state of sense relay Tray+ intern
Var=SCU1_flag_VSenserelayNegInt bit 25,1 /e:VtSig_SCU1_flag_PowerContPos // state of sense relay Tray- intern
Var=SCU1_flag_VSenserelayPosExt bit 26,1 /e:VtSig_SCU1_flag_PowerContPos // state of sense relay Tray+ extern
Var=SCU1_flag_VSenserelayNegExt bit 27,1 /e:VtSig_SCU1_flag_PowerContPos // state of sense relay Tray- extern
Var=SCU1_flag_eStopLoopNotClosed bit 32,1 /e:VtSig_SCU1_flag_eStopLoopNotClos // status of eStop loop
Var=SCU1_flag_InterventioneStop bit 33,1 /e:VtSig_SCU1_flag_InterventioneSto // status of intervention of SCU on eStop loop
Var=SCU1_flag_InterLockError bit 34,1 /e:VtSig_SCU1_flag_InterLockError // status of interlock (current is out of range)
Var=SCU1_flag_SourceInterlockLoop bit 35,1 /e:VtSig_SCU1_stat_Init // status of SCU source of interlock loop
Var=SCU1_flag_KL15 bit 36,1 /e:VtSig_SCU1_stat_Init // status of KL 15
Var=SCU1_flag_BMMSafe bit 37,1 /e:VtSig_SCU1_stat_Init // status of BMM safe
Var=SCU1_flag_SupplyMonitorWarning bit 38,1 /e:VtSig_SCU1_flag_SupplyMonitorWar // status of supply monitor warning
Var=SCU1_flag_CANGatewayStatus bit 39,1 /e:VtSig_SCU1_stat_Init // status of CAN gateway
Var=SCU1_flag_Led1 bit 40,1 /e:VtSig_SCU1_flag_Led1 // status od LED 1
Var=SCU1_flag_Led2 bit 41,1 /e:VtSig_SCU1_flag_Led1 // status of LED 2
Var=SCU1_flag_Led3 bit 42,1 /e:VtSig_SCU1_flag_Led1 // status of LED 3
Var=SCU1_flag_Warning bit 43,1 /e:VtSig_SCU1_flag_Led1 // warning flag
Var=SCU1_flag_Alarm bit 44,1 /e:VtSig_SCU1_flag_Led1 // alarm flag
Var=SCU1_flag_SilentCan1 bit 45,1 // management message CAN_1 has been silenced
Var=SCU1_flag_SilentCan2 bit 46,1 // management message CAN_2 has been silenced
Var=SCU1_flag_HSS1Locked bit 48,1 /e:VtSig_SCU1_stat_Init // switch on protection after thermal shut off of power MOS-FET
Var=SCU1_flag_HSS2Locked bit 49,1 /e:VtSig_SCU1_stat_Init // switch on protection after thermal shut off of power MOS-FET
Var=SCU1_flag_HSS3Locked bit 50,1 /e:VtSig_SCU1_stat_Init // switch on protection after thermal shut off of power MOS-FET
