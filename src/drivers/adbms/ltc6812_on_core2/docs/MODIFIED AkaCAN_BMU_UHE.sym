[M001_WriteEEPROMData_LTC]
ID=1E093801h // Write Data to the emulated EEPROM (Write Data to the emulated EEPROM)
Type=Extended
DLC=8
Var=M001_val_EEPROMWriteLength unsigned 0,8 // Length of EEPROM Data
Var=M001_val_EEPROMWriteIndex unsigned 8,8 // Index of EEPROM Data
Var=M001_val_EEPROMWriteAdress unsigned 16,16 // Adress of EEPROM Data
Var=M001_val_EEPROMWriteData unsigned 32,32 // EEPROM write data

[M001_ReadEEPROMData_LTC]
ID=1E093901h // Read Data from the emulated EEPROM (Read Data from the emulated EEPROM)
Type=Extended
DLC=8
Mux=M001_val_EEPROMDataIndex 0,8 FFh // Bit[6:4] Area, Bit[3:0] Index
Var=M001_val_EEPROMWriteArea unsigned 8,8 // Area of EEPROM Data:  0: Id Area, 1 Static, 2: Dynamic, 4: ID Copy, 5, Static Copy:6:Dynamic Copy
Var=M001_val_EEPROMWriteAdress unsigned 24,8 // Index of EEPROM Data
Var=M001_val_EEPROMWriteData unsigned 32,32 // EEPROM read data
