Var=SCU1_req_VSenseRelayBatPosDiag bit 8,1 /e:VtSig_BMM_req_ContactorPos // request for Sense relay Tray+ extern diagnostic
Var=SCU1_req_VSenseRelayBatNegDiag bit 9,1 /e:VtSig_BMM_req_ContactorPos // request for Sense relay Tray- extern diagnostic
Var=SCU1_req_VSenseRelaySysPosDiag bit 10,1 /e:VtSig_BMM_req_ContactorPos // request for Sense relay Tray+ intern diagnostic
Var=SCU1_req_VSenseRelaySysNegDiag bit 11,1 /e:VtSig_BMM_req_ContactorPos // request for Sense relay Tray- intern diagnostic
Var=SCU1_req_ShutdownDiag bit 16,1 /e:VtSig_BMM_req_ContactorPos // request to swirch off SCU hardware
